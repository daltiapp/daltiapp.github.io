22_3qPwPQISJW7LEoZsUj6tg83NlkFApZ.jpg","https://www.thekkf.or.kr/kkf_file/item/1761180627_aoE5tJjGtWZRxaHVHXtkRN7HG6wOyV.jpg","https://www.thekkf.or.kr/kkf_file/item/1761180633_vLGJ1LA5x0ZHa8sjKtT7l9iukFzsFc.jpg","https://www.thekkf.or.kr/kkf_file/item/1761180638_8dpCSE3DBPwlojc7rQ04wVjbPDjhNp.jpg"],"tables":[],"attachments":[{"label":"첨부파일1","url":"https://www.thekkf.or.kr/kkf_file/item/%EB%B9%84%EB%AC%B8%EB%93%B1%EB%A1%9D%EB%B2%88%ED%98%B8%20%EB%B0%9C%EA%B8%89%20%EA%B0%80%EC%9D%B4%EB%93%9C_%ED%95%9C%EA%B5%AD%EC%95%A0%EA%B2%AC%EC%97%B0%EB%A7%B9%20%EC%B6%9C%EC%A7%84%EA%B2%AC%20%EB%93%B1%EB%A1%9D%EC%9A%A9.pdf","file_name":"비문등록번호 발급 가이드_한국애견연맹 출진견 등록용.pdf","file_ext":".pdf","text":""}]}